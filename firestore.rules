rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------
    // 共通ヘルパー関数
    // -----------------------------------------------------------------
    
    // ユーザーが認証されているか確認
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // リクエスト送信者が指定されたUIDと一致するか確認
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // 指定されたUIDのユーザー文書を取得
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    // ユーザーが管理者（admin）またはシニアモデレータ（senior_moderator）か確認
    function isSeniorModeratorOrAdmin() {
      return isAuthenticated() && (
        getUserData(request.auth.uid).moderationTier == 'senior_moderator' ||
        getUserData(request.auth.uid).moderationTier == 'admin' ||
        getUserData(request.auth.uid).role == 'admin'
      );
    }
    
    // ユーザーがモデレータ（moderator）以上か確認
    function isModeratorOrAbove() {
      return isAuthenticated() && (
        getUserData(request.auth.uid).moderationTier == 'moderator' ||
        getUserData(request.auth.uid).moderationTier == 'senior_moderator' ||
        getUserData(request.auth.uid).moderationTier == 'admin'
      );
    }

    // システム管理者（moderationTier または users.role の admin）
    function isSystemAdmin() {
      return isAuthenticated() && (
        getUserData(request.auth.uid).moderationTier == 'admin' ||
        getUserData(request.auth.uid).role == 'admin'
      );
    }

    // metadata_genres への書き込み（モデレータ可決・管理者シード）
    function canWriteMetadataGenres() {
      return isNotBanned() && (isModeratorOrAbove() || isSystemAdmin());
    }

    // ユーザーがBANされていないか確認
    function isNotBanned() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          !('isBanned' in getUserData(request.auth.uid))
          || getUserData(request.auth.uid).isBanned == false
        );
    }

    // クイズ公開範囲（未設定は public）
    function quizDocVisibility(data) {
      return !('visibility' in data) || data.visibility == 'public'
        ? 'public'
        : data.visibility;
    }

    function isFollowingQuizAuthor(authorId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/follows/$(request.auth.uid + '_' + authorId));
    }

    function userHasProVisibilityAccess() {
      return isAuthenticated() && (
        getUserData(request.auth.uid).moderationTier == 'moderator'
        || getUserData(request.auth.uid).moderationTier == 'senior_moderator'
        || (
          getUserData(request.auth.uid).subscriptionTier in ['pro', 'premium']
          && getUserData(request.auth.uid).subscriptionStatus in ['active', 'trialing']
        )
      );
    }

    function visibilityChangeAllowed(oldVis, newVis) {
      return newVis == 'public'
        || newVis == oldVis
        || userHasProVisibilityAccess();
    }

    function canReadQuizVisibility(data) {
      return ('status' in data && data.status == 'draft')
        ? (isAuthenticated() && 'authorId' in data && data.authorId == request.auth.uid)
        : ('status' in data && data.status == 'suspended')
          ? (isSeniorModeratorOrAdmin() || (isAuthenticated() && 'authorId' in data && data.authorId == request.auth.uid))
          : (
            quizDocVisibility(data) == 'public'
            || (isAuthenticated() && 'authorId' in data && data.authorId == request.auth.uid)
            || isSeniorModeratorOrAdmin()
            || (quizDocVisibility(data) == 'followers' && 'authorId' in data && isFollowingQuizAuthor(data.authorId))
          );
    }

    // 課金フィールドが create 時にクライアントから設定されていないか確認
    function billingFieldsSafeOnCreate() {
      return (
        (!('subscriptionTier' in request.resource.data) || request.resource.data.subscriptionTier == 'free')
        && (!('isPremium' in request.resource.data) || request.resource.data.isPremium == false)
        && !('stripeCustomerId' in request.resource.data)
        && !('stripeSubscriptionId' in request.resource.data)
        && !('subscriptionStatus' in request.resource.data)
        && !('currentPeriodEnd' in request.resource.data)
      );
    }

    // 課金フィールドが update 時に変更されていないか確認
    function billingFieldsUnchanged() {
      return (
        (
          !('subscriptionTier' in resource.data)
            ? (!('subscriptionTier' in request.resource.data) || request.resource.data.subscriptionTier == 'free')
            : request.resource.data.subscriptionTier == resource.data.subscriptionTier
        )
        && (
          !('isPremium' in resource.data)
            ? !('isPremium' in request.resource.data)
            : request.resource.data.isPremium == resource.data.isPremium
        )
        && (
          !('stripeCustomerId' in resource.data)
            ? !('stripeCustomerId' in request.resource.data)
            : request.resource.data.stripeCustomerId == resource.data.stripeCustomerId
        )
        && (
          !('stripeSubscriptionId' in resource.data)
            ? !('stripeSubscriptionId' in request.resource.data)
            : request.resource.data.stripeSubscriptionId == resource.data.stripeSubscriptionId
        )
        && (
          !('subscriptionStatus' in resource.data)
            ? !('subscriptionStatus' in request.resource.data)
            : request.resource.data.subscriptionStatus == resource.data.subscriptionStatus
        )
        && (
          !('currentPeriodEnd' in resource.data)
            ? !('currentPeriodEnd' in request.resource.data)
            : request.resource.data.currentPeriodEnd == resource.data.currentPeriodEnd
        )
      );
    }

    // -----------------------------------------------------------------
    // users コレクションルール
    // -----------------------------------------------------------------
    match /users/{userId} {
      // プロフィールやランキングのために全ユーザーの読み取りを許可
      allow read: if true;
      
      // 新規作成時のルール
      allow create: if isOwner(userId) 
        // 一般ユーザーが勝手に特権ロールや高い評判スコアをセットできないようにする
        && request.resource.data.moderationTier == 'newcomer'
        && request.resource.data.reputationScore == 0
        && request.resource.data.deleteStatus == 'active'
        && billingFieldsSafeOnCreate();
        
      // 更新時のルール
      allow update: if isNotBanned() && (
        isOwner(userId)
        // 一般ユーザーが自分の特権情報を書き換えるのを禁止
        && request.resource.data.moderationTier == resource.data.moderationTier
        && request.resource.data.reputationScore == resource.data.reputationScore
        && request.resource.data.deleteStatus == resource.data.deleteStatus
        && billingFieldsUnchanged()
        // 他ユーザーからリアクションを受けた際の totalReactionsCount の更新のみ許可
        || (
          isAuthenticated()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalReactionsCount'])
        )
        // フォロー/フォロー解除時に他ユーザーの followersCount を ±1 のみ更新可能
        || (
          isAuthenticated()
          && isNotBanned()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt'])
          && request.resource.data.followersCount >= 0
          && (
            request.resource.data.followersCount
              == ('followersCount' in resource.data ? resource.data.followersCount : 0) + 1
            || request.resource.data.followersCount
              == ('followersCount' in resource.data ? resource.data.followersCount : 0) - 1
          )
        )
        // 管理者またはシニアモデレータによる特権書き換えは許可
        || isSeniorModeratorOrAdmin()
      );
        
      // ユーザーの完全削除は原則禁止（物理削除は管理者のみ、通常は deleteStatus を変更）
      allow delete: if isSeniorModeratorOrAdmin();
    }

    // -----------------------------------------------------------------
    // follows コレクションルール
    // -----------------------------------------------------------------
    match /follows/{followId} {
      allow read: if true;

      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.followerId == request.auth.uid
        && followId == request.auth.uid + '_' + request.resource.data.followingId;

      allow delete: if isAuthenticated() && isNotBanned()
        && resource.data.followerId == request.auth.uid;

      allow update: if false;
    }

    // -----------------------------------------------------------------
    // quizzes コレクションルール
    // -----------------------------------------------------------------
    match /quizzes/{quizId} {
      // 読み取りルール: ライフサイクル status と visibility に基づく
      allow read: if resource == null
        || canReadQuizVisibility(resource.data);
        
      // 作成ルール:
      // 認証済みユーザーのみ新規作成可能。初期の通報件数は0、ステータスは draft または published。
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.flagsCount == 0
        && request.resource.data.status in ['draft', 'published']
        && (
          !('visibility' in request.resource.data)
          || request.resource.data.visibility in ['public', 'private', 'followers']
        )
        && visibilityChangeAllowed(
          'public',
          quizDocVisibility(request.resource.data)
        );
        
      // プレイ数・ブックマーク数・良問評価・リーダーボードのみの更新（プレイ完了・ブックマーク操作など）
      function isPublicQuizStatsUpdate() {
        return isAuthenticated() && isNotBanned()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'playCount', 'bookmarksCount', 'leaderboard', 'leaderboardFirstPlay', 'leaderboardReplay', 'updatedAt',
                'positiveCount', 'negativeCount', 'tempPositiveCount', 'tempNegativeCount', 'reviewScore', 'reviewBadge'
              ])
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.status == resource.data.status
          && request.resource.data.flagsCount == resource.data.flagsCount;
      }

      // 更新ルール:
      // 1. 作成者本人の場合は、タイトルや問題内容の変更のみ許可（ステータスや通報件数の不正操作を禁止）
      // 2. モデレータ・シニアモデレータ・管理者の場合は、通報対応やステータス変更のための更新を許可
      // 3. 認証済みユーザーによる playCount / bookmarksCount / リーダーボードの更新
      allow update: if isNotBanned() && (
        (
          isOwner(resource.data.authorId)
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.status == resource.data.status
          && request.resource.data.flagsCount == resource.data.flagsCount
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['visibility'])
            || visibilityChangeAllowed(
              quizDocVisibility(resource.data),
              quizDocVisibility(request.resource.data)
            )
          )
        ) || isModeratorOrAbove() || isPublicQuizStatsUpdate()
      );
      
      // 削除ルール: 作成者本人、またはモデレータ以上のみ許可
      allow delete: if isNotBanned() && (isOwner(resource.data.authorId) || isModeratorOrAbove());
    }

    // -----------------------------------------------------------------
    // metadata_tags / metadata_genres（Phase 6）
    // -----------------------------------------------------------------
    match /metadata_tags/{tagId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.id == tagId
        && request.resource.data.canonicalId == null
        && request.resource.data.mergedTagIds == [];
      allow update: if isAuthenticated() && isNotBanned()
        && request.resource.data.id == resource.data.id
        && (
          (resource.data.canonicalId == null && request.resource.data.canonicalId != null)
          || request.resource.data.mergedTagIds.hasAll(resource.data.mergedTagIds)
        );
    }

    match /metadata_genres/{genreId} {
      allow read: if true;
      allow create: if canWriteMetadataGenres();
      allow update: if canWriteMetadataGenres();
    }

    match /mergeRequests/{requestId} {
      allow read: if true;
      allow create: if isModeratorOrAbove() && isNotBanned()
        && request.resource.data.status == 'pending';
      allow update: if isModeratorOrAbove() && isNotBanned();
      allow delete: if false;
    }

    match /genreRequests/{requestId} {
      allow read: if true;
      allow create: if isSystemAdmin() && isNotBanned()
        && request.resource.data.status == 'pending';
      allow update: if isSystemAdmin() && isNotBanned();
      allow delete: if false;
    }

    // -----------------------------------------------------------------
    // questions コレクションルール
    // -----------------------------------------------------------------
    match /questions/{questionId} {
      allow read: if true;

      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.authorId == request.auth.uid;

      allow update: if isNotBanned() && (
        isOwner(resource.data.authorId)
        || (
          isAuthenticated()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['bookmarksCount', 'correctCount', 'incorrectCount', 'updatedAt'])
        )
      );

      allow delete: if isNotBanned() && isOwner(resource.data.authorId);
    }

    // -----------------------------------------------------------------
    // bookmarks コレクションルール
    // -----------------------------------------------------------------
    match /bookmarks/{bookmarkId} {
      // get で未作成ドキュメントを読むと resource は null（isBookmarked の存在確認）
      allow read: if isAuthenticated() && (
        resource == null
        || resource.data.userId == request.auth.uid
      );

      // id はドキュメントパス (bookmarkId) に格納。createConverter が本文から id を除去するため data.id は検証しない
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.userId == request.auth.uid
        && bookmarkId == request.resource.data.userId + '_' + request.resource.data.targetId
        && request.resource.data.targetType in ['quiz', 'question'];

      allow delete: if isAuthenticated() && isNotBanned() && resource.data.userId == request.auth.uid;

      allow update: if false;
    }

    // -----------------------------------------------------------------
    // attempts コレクションルール
    // -----------------------------------------------------------------
    match /attempts/{attemptId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() && isNotBanned()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() && isNotBanned() && resource.data.userId == request.auth.uid;
    }

    // -----------------------------------------------------------------
    // search_logs コレクションルール
    // -----------------------------------------------------------------
    match /search_logs/{logId} {
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // -----------------------------------------------------------------
    // flags (通報) コレクションルール
    // -----------------------------------------------------------------
    match /flags/{flagId} {
      // 通報一覧の閲覧はモデレータ以上のみ許可
      allow read: if isModeratorOrAbove();
      
      // 通報の作成ルール:
      // 認証済みユーザーのみ新規作成可能。通報者IDは自身のUIDと一致すること。
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.reporterId == request.auth.uid;
        
      // 通報データの変更・削除はモデレータ以上のみ許可
      allow update, delete: if isModeratorOrAbove() && isNotBanned();
    }

    // -----------------------------------------------------------------
    // feedbackReports (間違い指摘) コレクションルール
    // -----------------------------------------------------------------
    match /feedbackReports/{reportId} {
      // クイズ作成者は自分宛ての指摘、報告者は自分の送信履歴を閲覧可能
      allow read: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid
        || resource.data.reporterId == request.auth.uid
      );

      // 認証済みユーザーが指摘を送信（報告者IDは自身、初期ステータスは open）
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.category in ['typo', 'fact', 'alternative'];

      // 更新ルール:
      // 1. クイズ作成者が status を resolved に更新可能
      // 2. 報告者自身が open 状態の指摘の category / content / updatedAt を修正可能
      allow update: if isAuthenticated() && isNotBanned() && (
        (
          resource.data.creatorId == request.auth.uid
          && resource.data.status == 'open'
          && request.resource.data.status == 'resolved'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        ) || (
          resource.data.reporterId == request.auth.uid
          && resource.data.status == 'open'
          && request.resource.data.status == 'open'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['category', 'content', 'updatedAt'])
        )
      );

      allow delete: if false;
    }

    // -----------------------------------------------------------------
    // quizReviews コレクションルール
    // -----------------------------------------------------------------
    match /quizReviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.reviewerId == request.auth.uid
        && reviewId == request.auth.uid + '_' + request.resource.data.quizId;
      allow update: if isAuthenticated() && isNotBanned()
        && resource.data.reviewerId == request.auth.uid
        && request.resource.data.reviewerId == request.auth.uid;
      allow delete: if isAuthenticated() && isNotBanned() && (
        resource.data.reviewerId == request.auth.uid || isModeratorOrAbove()
      );
    }

    // -----------------------------------------------------------------
    // reviewResetRequests コレクションルール
    // -----------------------------------------------------------------
    match /reviewResetRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.requesterId == request.auth.uid;
      allow update: if isModeratorOrAbove() && isNotBanned();
      allow delete: if false;
    }

    // -----------------------------------------------------------------
    // reactions コレクションルール
    // -----------------------------------------------------------------
    match /reactions/{reactionId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.senderId == request.auth.uid
        && reactionId == request.auth.uid + '_' + request.resource.data.quizId + '_' + request.resource.data.type;
      allow update, delete: if false;
    }

    // -----------------------------------------------------------------
    // notifications (通知) コレクションルール
    // -----------------------------------------------------------------
    match /notifications/{notificationId} {
      // 自身の通知のみ読み取り可能
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // 認証済みでBANされていないユーザーが通知を作成可能
      allow create: if isAuthenticated() && isNotBanned();
      
      // 自身の通知の既読状態のみ更新可能
      allow update: if isAuthenticated() && isNotBanned()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      
      // 自身の通知のみ削除可能
      allow delete: if isAuthenticated() && isNotBanned()
        && resource.data.userId == request.auth.uid;
    }

    // -----------------------------------------------------------------
    // announcements (運営からのお知らせ) コレクションルール
    // -----------------------------------------------------------------
    match /announcements/{announcementId} {
      allow read: if resource == null || resource.data.status == 'published' || isSystemAdmin();
      allow write: if isSystemAdmin();
    }

    // -----------------------------------------------------------------
    // adminLogs (管理者ログ) コレクションルール
    // -----------------------------------------------------------------
    match /adminLogs/{logId} {
      // 管理者監査ログの閲覧はシニアモデレータ/管理者のみ許可
      allow read: if isSeniorModeratorOrAdmin();
      // クライアントからの直接の書き込み・変更・削除は完全に禁止（サーバーサイドAPIから特権実行のみ）
      allow write: if false;
    }

    // -----------------------------------------------------------------
    // stripe_processed_events (Stripe Webhook 冪等ログ) コレクションルール
    // -----------------------------------------------------------------
    match /stripe_processed_events/{eventId} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------
    // dailyAiAuthoringCounts（AI 作問・サムネ日次カウンタ）
    // -----------------------------------------------------------------
    match /users/{userId}/dailyAiAuthoringCounts/{docId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }
  }
}
